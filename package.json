{
  "name": "rifqa-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "test": "npm run test:api",
    "test:api": "tsc -p tsconfig.tests.json && node .tmp-tests/tests/api.test.js && node .tmp-tests/tests/retrieval.test.js",
    "test:e2e": "playwright test",
    "test:retrieval": "tsc -p tsconfig.tests.json && node .tmp-tests/tests/retrieval.test.js",
    "seed:reviewed-content": "node scripts/sync-reviewed-content.mjs",
    "typecheck": "tsc -b && tsc -p tsconfig.api.json --noEmit",
    "build": "npm run typecheck && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
